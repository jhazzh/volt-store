{
  "name": "ecommerce-store",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:prod": "set -a && . ./.env.prod.local && set +a && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest --project=unit",
    "test:e2e": "playwright test",
    "test:walk": "INCLUDE_WALK=1 playwright test purchase-walk",
    "test:a11y": "playwright test a11y",
    "test:perf": "playwright test perf",
    "seed": "node --import ./scripts/load-env.mjs --experimental-websocket scripts/seed.mjs",
    "seed:digital": "node --import ./scripts/load-env.mjs --experimental-websocket scripts/seed-digital.mjs",
    "seed:reviews": "node --import ./scripts/load-env.mjs --experimental-websocket scripts/seed-reviews.mjs",
    "seed:specs": "node --import ./scripts/load-env.mjs --experimental-websocket scripts/seed-specs.mjs",
    "update:images": "node --import ./scripts/load-env.mjs --experimental-websocket scripts/update-images.mjs",
    "embed": "node --import ./scripts/load-env.mjs --experimental-websocket scripts/embed-products.mjs",
    "create:bucket": "node --import ./scripts/load-env.mjs --experimental-websocket scripts/create-bucket.mjs",
    "make:admin": "node --import ./scripts/load-env.mjs --experimental-websocket scripts/make-admin.mjs",
    "revalidate": "node --import ./scripts/load-env.mjs scripts/revalidate.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@paypal/paypal-server-sdk": "^2.4.0",
    "@supabase/ssr": "^0.12.1",
    "@supabase/supabase-js": "^2.109.0",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "^0.0.1",
    "stripe": "^22.3.1",
    "xendit-node": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@chromatic-com/storybook": "^5.2.1",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/addon-mcp": "^0.7.0",
    "@storybook/addon-vitest": "^10.5.0",
    "@storybook/nextjs-vite": "^10.5.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/ui": "^4.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-storybook": "^10.5.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "storybook": "^10.5.0",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
