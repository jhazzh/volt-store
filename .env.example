# Copy to .env.local and fill from Supabase → Project Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Server-only. Never expose to the browser.
SUPABASE_SECRET_KEY=sb_secret_xxx

# Server-only. Shared secret for POST /api/revalidate. Any long random string.
REVALIDATE_SECRET=

# Stripe test keys — dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
# From `stripe listen` (dev) or dashboard webhook endpoint (prod)
STRIPE_WEBHOOK_SECRET=whsec_xxx
